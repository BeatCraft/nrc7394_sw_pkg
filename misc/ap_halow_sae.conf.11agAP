
ctrl_interface=/var/run/hostapd
country_code=JP
interface=wlan0
wds_sta=1
bridge=br0


driver=nl80211

ieee80211d=1

hw_mode=g
channel=1                  # 空き状況に合わせて 1/6/11/13 を選択
ieee80211n=1
wmm_enabled=1
require_ht=1

# HT40（拡張方向は実使用チャネルに合わせて調整）
ht_capab=[HT40+][SHORT-GI-20][SHORT-GI-40]
# 例）channel=6 で下側に拡張するなら [HT40-] に変更

ssid=RPi4BP_AP_24G
auth_algs=1
wpa=2
wpa_key_mgmt=WPA-PSK
rsn_pairwise=CCMP
wpa_passphrase=12345678

